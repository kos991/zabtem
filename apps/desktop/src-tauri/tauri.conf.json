{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zabtem",
  "version": "0.0.0",
  "identifier": "dev.zabtem.app",
  "build": {
    "beforeDevCommand": "corepack pnpm dev",
    "beforeBuildCommand": "corepack pnpm build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist/web"
  },
  "app": {
    "windows": [
      {
        "title": "Zabtem",
        "width": 1200,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
