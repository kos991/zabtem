{
  "name": "zabtem",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit && corepack pnpm --filter @zabtem/desktop typecheck",
    "test": "vitest run",
    "generate:template": "tsx scripts/generate-template.ts",
    "validate:template": "tsx scripts/validate-template.ts",
    "build": "tsx scripts/build-skeleton.ts && corepack pnpm --filter @zabtem/desktop build",
    "desktop:dev": "corepack pnpm --filter @zabtem/desktop dev",
    "desktop:build": "corepack pnpm --filter @zabtem/desktop build"
  },
  "devDependencies": {
    "@testing-library/react": "latest",
    "@testing-library/user-event": "latest",
    "@types/better-sqlite3": "latest",
    "@types/node": "^22.10.10",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "jsdom": "latest",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "yaml": "^2.7.0"
  }
}
